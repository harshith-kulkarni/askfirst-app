# ─── Copy this file to .env and fill in your values ───────────────────────────

# LLM Provider: openrouter (default) | openai | groq | gemini
LLM_PROVIDER=openrouter

# Model — pick any from https://openrouter.ai/models
# Free tier examples:
#   meta-llama/llama-3.1-8b-instruct:free
#   mistralai/mistral-7b-instruct:free
#   google/gemma-2-9b-it:free
LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free

# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: identifies your app in the OpenRouter dashboard
APP_URL=http://localhost:8501
APP_NAME=AI Chat App

# --- Fallback providers (only needed if switching LLM_PROVIDER) ---
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# SQLite database path
DATABASE_URL=sqlite:///./chat.db

# FastAPI backend URL as seen by Streamlit
API_URL=http://localhost:8000
